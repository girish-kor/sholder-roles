{
  "name": "@sholder/roles",
  "version": "1.0.0",
  "description": "Enterprise role orchestration system as automated agents",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./core": {
      "import": "./dist/esm/core/index.js",
      "require": "./dist/cjs/core/index.cjs"
    },
    "./roles": {
      "import": "./dist/esm/roles/index.js",
      "require": "./dist/cjs/roles/index.cjs"
    },
    "./engine": {
      "import": "./dist/esm/engine/index.js",
      "require": "./dist/cjs/engine/index.cjs"
    },
    "./orchestrator": {
      "import": "./dist/esm/orchestrator/index.js",
      "require": "./dist/cjs/orchestrator/index.cjs"
    },
    "./registry": {
      "import": "./dist/esm/registry/index.js",
      "require": "./dist/cjs/registry/index.cjs"
    },
    "./runtime": {
      "import": "./dist/esm/runtime/index.js",
      "require": "./dist/cjs/runtime/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/cjs-rename.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "node bench/runner.mjs",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "prepare": "husky install"
  },
  "keywords": [
    "ontology",
    "roles",
    "agents",
    "orchestration",
    "enterprise"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.4",
    "vitest": "^1.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
